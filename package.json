{
  "name": "antigravity-jinc-skills",
  "version": "1.0.0",
  "scripts": {
    "format": "prettier --write \"**/*.{json,md}\"",
    "check:all": "python .agents/scripts/verify_all.py .",
    "check:core": "python .agents/scripts/checklist.py .",
    "preview:start": "python .agents/scripts/auto_preview.py start",
    "preview:stop": "python .agents/scripts/auto_preview.py stop",
    "session": "python .agents/scripts/session_manager.py status ."
  },
  "lint-staged": {
    "**/*.md": [
      "python .agents/scripts/sdd_validator.py",
      "python .agents/scripts/sync_architecture.py",
      "git add .agents/ARCHITECTURE.md",
      "prettier --write"
    ],
    "**/*.json": [
      "prettier --write"
    ]
  }
}
